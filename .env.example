# ─────────────────────────────────────────────────────────────────────────────
# Environment Variable Reference
#
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing real secrets.
#
# For Vercel deployments, set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# Variable naming conventions:
#   VITE_*          → Exposed to the browser in Vite projects
#   NEXT_PUBLIC_*   → Exposed to the browser in Next.js projects
#   All others      → Server-side only (never sent to the browser)
# ─────────────────────────────────────────────────────────────────────────────


# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production  ← set by Vercel automatically in production builds


# ─── API ─────────────────────────────────────────────────────────────────────
# Replace with your actual backend API base URL.
# Local:       http://localhost:3001
# Production:  https://api.yourdomain.com

# Use the prefix that matches your frontend framework:
VITE_API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001


# ─── Feature Flags (optional) ────────────────────────────────────────────────
# VITE_ENABLE_ANALYTICS=false


# ─── Third-Party Integrations (examples — add as needed) ─────────────────────
# VITE_SENTRY_DSN=
# VITE_GOOGLE_ANALYTICS_ID=
