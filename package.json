{
  "name": "frontend-starter-template",
  "version": "0.1.0",
  "description": "A reusable frontend starter template.",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "echo \"Replace with your framework dev command, e.g.: vite\" && exit 1",
    "build": "echo \"Replace with your framework build command, e.g.: vite build\" && exit 1",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/?(*.)+(spec|test).js"
    ]
  }
}
