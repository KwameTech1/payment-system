# Normalize line endings to LF for all text files in the repository.
# This ensures consistent behavior across Windows, macOS, and Linux.

* text=auto eol=lf

# Explicitly keep binary files untouched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
